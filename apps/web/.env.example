# Frontend public data read-only skeleton
# VITE_SUPABASE_URL may point to a local or public Supabase URL.
# Do not commit any production secret or private environment file.
# VITE_SUPABASE_ANON_KEY may only use an anon public key.
# Do not use a service role key in frontend.
# VITE_PUBLIC_DATA_PROVIDER=mock is the safe default.
# Change VITE_PUBLIC_DATA_PROVIDER to supabase only for local provider smoke.
# The smoke script only tests approved public views.
# Do not commit .env.local.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PUBLIC_DATA_PROVIDER=mock
