# Frontend public data read-only skeleton
# VITE_SUPABASE_ANON_KEY may only use an anon public key.
# Do not use a service role key in frontend.
# VITE_PUBLIC_DATA_PROVIDER currently defaults to mock.
# Production secrets must never be committed to this repository.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PUBLIC_DATA_PROVIDER=mock
